{
  "name": "forge-lang-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @forge/language build && pnpm --filter @forge/generators build && pnpm --filter @forge/cli build",
    "forge": "node packages/cli/dist/index.js",
    "clean": "pnpm --filter './packages/*' clean"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.17.1"
}
